# Cloudflare Pages: serve index.html for /embed and /embed/<addr> so the
# JS-side router can handle both clean URL forms. Status 200 = rewrite,
# the URL bar keeps showing /embed/<addr>.
/embed       /index.html       200
/embed/*     /index.html       200

# Configurator (owner-only editor for the dustopia NFT they hold).
# configure/index.html is auto-served by Pages at /configure (no rewrite
# needed — Pages handles directory index.html natively, which avoids the
# .html→pretty-URL 308 loop the previous /configure.html rewrite caused).
# Sub-paths /configure/<tokenId> still need an explicit rewrite so the
# JS router on configure/index.html can parse them.
/configure/* /configure/index.html 200
