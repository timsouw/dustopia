# Cloudflare Pages: serve index.html for /embed and /embed/<addr> so the
# JS-side router can handle both clean URL forms. Status 200 = rewrite,
# the URL bar keeps showing /embed/<addr>.
/embed       /index.html       200
/embed/*     /index.html       200

# Configurator (owner-only editor for the dustopia NFT they hold). Same
# rewrite trick as /embed so /configure/<tokenId> deep links work without
# a hash, and the configure.html JS router parses the path.
/configure   /configure.html   200
/configure/* /configure.html   200
