# Cloudflare Pages serves directory index.html natively for /foo when
# foo/index.html exists, so the bare /embed and /configure URLs need no
# explicit rewrite. The wildcards below catch sub-paths so the JS-side
# router on each page can parse /embed/<addr> and /configure/<tokenId>
# deep links without a hash. Status 200 = rewrite (URL bar unchanged).
/embed/*     /embed/index.html      200
/configure/* /configure/index.html  200
